# Copy this file to .env and fill in real values
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/restaurant_reservations
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed frontend origins for CORS.
# Leave empty locally to allow all origins. In production set to your
# deployed frontend, e.g. https://your-app.vercel.app
CORS_ORIGIN=

# Used only by the seed script to create the initial admin user
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin1234
